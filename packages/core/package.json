{
  "name": "@versatly/clawvault-core",
  "version": "3.1.0",
  "description": "Core engine for ClawVault — search, templates, observation, workgraph",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*",
      "import": "./dist/*"
    }
  },
  "scripts": {
    "build": "tsc --build --force",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "chalk": "^5.3.0",
    "chokidar": "^5.0.0",
    "glob": "^10.3.10",
    "gray-matter": "^4.0.3",
    "natural": "^6.10.4",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}

{
  "name": "@clawvault/openclaw-plugin",
  "version": "2.1.0",
  "description": "ClawVault memory provider plugin for OpenClaw",
  "type": "module",
  "main": "index.ts",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs"
    },
    "./provider": {
      "import": "./dist/provider/index.js",
      "types": "./dist/provider/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "keywords": [
    "openclaw",
    "clawvault",
    "memory",
    "plugin",
    "langchain",
    "crewai",
    "autogen"
  ],
  "license": "MIT",
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "clawvault": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
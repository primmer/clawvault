{
  "name": "@versatly/clawvault-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for ClawVault \u2014 structured agent memory with hybrid search, observation, and context management",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "node --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "clawvault",
    "memory",
    "agent",
    "search",
    "openclaw"
  ],
  "author": "Versatly",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Versatly/clawvault",
    "directory": "packages/sdk"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  }
}
{
  "schemaVersion": 3,
  "expectedCheckLabels": [
    "openclaw CLI available",
    "plugin manifest",
    "plugin extensions registration",
    "skill metadata"
  ],
  "cases": [
  {
    "name": "healthy",
    "description": "expected strict pass.",
    "expectedExitCode": 0,
    "expectedWarnings": 0,
    "expectedErrors": 0,
    "expectedCheckStatuses": {
      "openclaw CLI available": "ok",
      "plugin manifest": "ok",
      "plugin extensions registration": "ok",
      "skill metadata": "ok"
    }
  },
  {
    "name": "broken-openclaw-cli",
    "description": "warning when openclaw CLI exists but is not runnable.",
    "openclawExitCode": 2,
    "expectedExitCode": 1,
    "expectedWarnings": 1,
    "expectedErrors": 0,
    "expectedCheckStatuses": {
      "openclaw CLI available": "warn"
    },
    "expectedDetailIncludes": {
      "openclaw CLI available": "exited with code 2"
    },
    "expectedHintIncludes": {
      "openclaw CLI available": "runnable in PATH"
    }
  },
  {
    "name": "broken-openclaw-signal",
    "description": "warning when openclaw CLI invocation is terminated by signal.",
    "openclawSignal": "SIGTERM",
    "expectedExitCode": 1,
    "expectedWarnings": 1,
    "expectedErrors": 0,
    "expectedCheckStatuses": {
      "openclaw CLI available": "warn"
    },
    "expectedDetailIncludes": {
      "openclaw CLI available": "terminated by signal SIGTERM"
    },
    "expectedHintIncludes": {
      "openclaw CLI available": "execute normally in PATH"
    }
  },
  {
    "name": "missing-openclaw-cli",
    "description": "warning when openclaw CLI is missing from PATH.",
    "openclawMissing": true,
    "expectedExitCode": 1,
    "expectedWarnings": 1,
    "expectedErrors": 0,
    "expectedCheckStatuses": {
      "openclaw CLI available": "warn"
    },
    "expectedDetailIncludes": {
      "openclaw CLI available": "binary not found"
    },
    "expectedHintIncludes": {
      "openclaw CLI available": "Install OpenClaw CLI"
    }
  },
  {
    "name": "missing-manifest",
    "description": "error when openclaw.plugin.json is missing.",
    "expectedExitCode": 1,
    "expectedWarnings": 0,
    "expectedErrors": 1,
    "expectedCheckStatuses": {
      "plugin manifest": "error"
    },
    "expectedDetailIncludes": {
      "plugin manifest": "openclaw.plugin.json not found"
    },
    "expectedHintIncludes": {
      "plugin manifest": "openclaw.plugin.json"
    }
  },
  {
    "name": "missing-extensions",
    "description": "error when openclaw.extensions is missing from package.json.",
    "expectedExitCode": 1,
    "expectedWarnings": 0,
    "expectedErrors": 1,
    "expectedCheckStatuses": {
      "plugin extensions registration": "error"
    },
    "expectedDetailIncludes": {
      "plugin extensions registration": "Missing openclaw.extensions"
    },
    "expectedHintIncludes": {
      "plugin extensions registration": "openclaw.extensions"
    }
  },
  {
    "name": "missing-entry-file",
    "description": "error when extension entry file does not exist.",
    "expectedExitCode": 1,
    "expectedWarnings": 0,
    "expectedErrors": 1,
    "expectedCheckStatuses": {
      "plugin extensions registration": "error"
    },
    "expectedDetailIncludes": {
      "plugin extensions registration": "Entry file(s) not found"
    },
    "expectedHintIncludes": {
      "plugin extensions registration": "npm run build"
    }
  },
  {
    "name": "incomplete-manifest",
    "description": "error when openclaw.plugin.json is missing required fields.",
    "expectedExitCode": 1,
    "expectedWarnings": 0,
    "expectedErrors": 1,
    "expectedCheckStatuses": {
      "plugin manifest": "error"
    },
    "expectedDetailIncludes": {
      "plugin manifest": "missing kind"
    }
  },
  {
    "name": "missing-skill-openclaw",
    "description": "warning for missing metadata.openclaw in SKILL.md.",
    "expectedExitCode": 1,
    "expectedWarnings": 1,
    "expectedErrors": 0,
    "expectedCheckStatuses": {
      "skill metadata": "warn"
    },
    "expectedDetailIncludes": {
      "skill metadata": "Missing metadata.openclaw"
    },
    "expectedHintIncludes": {
      "skill metadata": "metadata.openclaw"
    }
  },
  {
    "name": "missing-skill-file",
    "description": "warning for missing SKILL.md file entirely.",
    "expectedExitCode": 1,
    "expectedWarnings": 1,
    "expectedErrors": 0,
    "expectedCheckStatuses": {
      "skill metadata": "warn"
    },
    "expectedDetailIncludes": {
      "skill metadata": "SKILL.md not found"
    },
    "expectedHintIncludes": {
      "skill metadata": "Ensure SKILL.md is present"
    }
  }
  ]
}
